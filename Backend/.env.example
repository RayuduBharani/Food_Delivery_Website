# ──────────────────────────────────────────────────────────────────────────────
# .env.example — Copy this file to .env and fill in your real values.
# NEVER commit your actual .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Local dev port (not used on Vercel — Vercel assigns its own port)
PORT=8000

# MongoDB connection string
# • Local dev  → mongodb://127.0.0.1:27017/FoodDeliveryWebsite
# • Production → Use a MongoDB Atlas URI (required for Vercel)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/FoodDeliveryWebsite?retryWrites=true&w=majority

# Secret key for signing JWT tokens — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_here

# Allowed CORS origin (your frontend URL)
# • Local dev  → http://localhost:5175
# • Production → https://your-frontend.vercel.app
CLIENT_URL=http://localhost:5175
